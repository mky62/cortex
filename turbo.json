{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_SECRET_ACCESS_KEY",
        "CLERK_JWT_ISSUER_DOMAIN",
        "CLERK_SECRET_KEY",
        "CONVEX_DEPLOYMENT",
        "CONVEX_SITE_URL",
        "CONVEX_URL",
        "GEMINI_API_KEY",
        "OPENROUTER_API_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "docs/**"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputs": []
    }
  }
}
